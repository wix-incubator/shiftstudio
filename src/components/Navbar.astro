---
import { BUSINESS_NAME } from '../utils/constants';
---

<header class="fixed top-0 left-0 w-full backdrop-blur-md bg-zinc-950/92 z-50 border-b border-white/10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <div class="flex items-center">
        <a href="/" class="flex items-center gap-3 text-white">
          <span class="grid h-9 w-9 place-items-center rounded-lg bg-primary text-sm font-black text-white shadow-[0_0_24px_rgba(227,22,71,0.35)]">SS</span>
          <span class="hidden text-lg font-black uppercase tracking-wide sm:inline">{BUSINESS_NAME}</span>
          <span class="text-lg font-black uppercase tracking-wide sm:hidden">Shift</span>
        </a>
      </div>
      <nav class="flex items-center gap-1">
        <a href="/" class="px-3 py-2 text-sm font-semibold text-white/70 hover:text-white transition-colors">Home</a>
        <a href="/schedule" class="rounded-lg bg-white px-3 py-2 text-sm font-black uppercase tracking-wide text-zinc-950 transition-colors hover:bg-secondary">Book</a>
      </nav>
    </div>
  </div>
</header>
