---
import { BUSINESS_NAME } from '../utils/constants';

const currentYear = new Date().getFullYear();
---

<footer class="px-4 py-10 bg-zinc-950 text-white">
  <div class="max-w-7xl mx-auto flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="text-sm font-black uppercase tracking-wide">{BUSINESS_NAME}</p>
      <p class="mt-1 text-sm text-white/60">Wix Headless booking for classes, consults, and paid performance sessions.</p>
    </div>
    <p class="text-sm text-white/60">
      &copy; {currentYear} {BUSINESS_NAME}. Move with intent.
    </p>
  </div>
</footer>
