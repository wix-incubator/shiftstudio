---
import { BUSINESS_NAME } from '../utils/constants';

const currentYear = new Date().getFullYear();
---

<footer class="px-4 py-12 bg-zinc-950 text-white">
  <div class="max-w-7xl mx-auto grid gap-8 md:grid-cols-[1fr_auto] md:items-end">
    <div>
      <p class="text-sm font-black uppercase tracking-wide text-secondary">{BUSINESS_NAME}</p>
      <p class="mt-2 max-w-xl text-sm leading-6 text-white/60">Wix Headless booking for classes, consults, paid performance sessions, and confirmation flows that keep the studio brand in motion.</p>
    </div>
    <div class="flex flex-col gap-2 text-sm text-white/60 sm:items-end">
      <a class="text-white transition-colors hover:text-secondary" href="/schedule">Open scheduler</a>
      <p>&copy; {currentYear} {BUSINESS_NAME}. Powered by Wix Headless.</p>
      <a class="font-semibold text-white transition-colors hover:text-secondary" href="https://www.wix-headless.dev" target="_blank" rel="noreferrer">Built with wix-headless.dev</a>
      <a class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-white/20 text-white transition-colors hover:border-secondary hover:text-secondary" href="https://github.com/wix-incubator/shiftstudio" target="_blank" rel="noreferrer" aria-label="View source on GitHub" title="View source on GitHub">
        <svg class="h-4 w-4 fill-current" aria-hidden="true" viewBox="0 0 24 24">
          <path d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.79 8.21 11.38.6.11.82-.26.82-.58 0-.29-.01-1.05-.02-2.06-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.21.09 1.85 1.24 1.85 1.24 1.07 1.84 2.81 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.34-5.47-5.94 0-1.31.47-2.39 1.24-3.23-.12-.3-.54-1.53.12-3.18 0 0 1.01-.32 3.3 1.23.96-.27 1.98-.4 3-.41 1.02.01 2.04.14 3 .41 2.29-1.55 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.77.84 1.24 1.92 1.24 3.23 0 4.62-2.81 5.63-5.49 5.93.43.37.81 1.1.81 2.22 0 1.61-.02 2.9-.02 3.3 0 .32.22.7.83.58A12.01 12.01 0 0 0 24 12.5C24 5.87 18.63.5 12 .5Z" />
        </svg>
      </a>
    </div>
  </div>
</footer>
