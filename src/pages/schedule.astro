---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import DatePicker from "../components/DatePicker.astro";
import TimeSlots from "../components/TimeSlots.astro";
import BookingForm from "../components/BookingForm.astro";
import SessionType from "../components/SessionType.astro";
import BackButton from "../components/ui/BackButton.astro";
import "../styles/global.css";
import { BUSINESS_NAME } from "../utils/constants";
---

<Layout>
  <div class="min-h-screen bg-[#f7f8ef]">
    <Navbar />

    <div class="max-w-7xl mx-auto pt-28 pb-16 px-4 sm:px-6 lg:px-8">
      <div class="mb-6">
        <BackButton href="/" text="Back to Home" />
      </div>

      <section class="shift-schedule-header mb-8 animate-fade-up">
        <div>
          <p class="mb-4 text-sm font-black uppercase tracking-wide text-secondary">Shift booking desk / live Wix inventory</p>
          <h1 class="max-w-3xl text-4xl font-black leading-tight text-white md:text-6xl">
            Choose a session and lock the next training window.
          </h1>
        </div>
        <div class="space-y-4">
          <p class="max-w-2xl text-base leading-7 text-white/70">
            Wix Headless pulls service type, availability, and checkout behavior into this branded scheduler, so an intro assessment and a paid performance block can share one fast booking path.
          </p>
          <div class="shift-schedule-pulse">
            <span></span>
            <strong>Availability refreshes from Wix Bookings after every date or service change.</strong>
          </div>
        </div>
      </section>

      <div class="mb-8 grid gap-3 sm:grid-cols-3 animate-fade-up delay-100">
        <div class="shift-step-card">
          <p>Step 1</p>
          <strong>Pick session type</strong>
          <span>No-fee intro or paid performance block.</span>
        </div>
        <div class="shift-step-card">
          <p>Step 2</p>
          <strong>Choose live availability</strong>
          <span>Slots are queried from Wix for the selected service.</span>
        </div>
        <div class="shift-step-card">
          <p>Step 3</p>
          <strong>Confirm with {BUSINESS_NAME}</strong>
          <span>Confirm free bookings or move into checkout.</span>
        </div>
      </div>

      <div class="max-w-2xl mx-auto mb-8 animate-fade-up delay-100">
        <SessionType />
      </div>

      <div class="shift-scheduler-grid grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="animate-fade-up delay-200">
          <DatePicker />
        </div>

        <div class="animate-fade-up delay-300">
          <TimeSlots />
        </div>

        <div id="booking-form" class="animate-fade-up delay-400">
          <BookingForm />
        </div>
      </div>
    </div>

    <Footer />
  </div>
</Layout>
