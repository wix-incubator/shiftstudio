---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import { BUSINESS_NAME } from "../utils/constants";

const features = [
  {
    title: "Live studio availability",
    description: "Wix Headless keeps the schedule connected to real class inventory, so open training windows stay current.",
    marker: "01",
  },
  {
    title: "Free or paid sessions",
    description: "Intro assessments can confirm directly, while paid training blocks can move into a Wix checkout flow.",
    marker: "02",
  },
  {
    title: "Fast confirmation loop",
    description: "Guests pick a date, choose a slot, and get a polished confirmation without leaving the branded experience.",
    marker: "03",
  },
];
---

<Layout>
  <div class="min-h-screen overflow-hidden bg-[#f7f8ef] text-foreground">
    <Navbar />

    <main>
      <section class="shift-hero relative pt-28 pb-16 md:pt-36 md:pb-24">
        <div class="max-w-7xl mx-auto grid gap-10 px-4 sm:px-6 lg:grid-cols-[1.02fr_0.98fr] lg:items-center lg:px-8">
          <div>
            <p class="mb-5 inline-flex rounded-lg bg-zinc-950 px-3 py-2 text-xs font-black uppercase tracking-wide text-white animate-fade-up">
              Built for high-output booking
            </p>
            <h1 class="max-w-4xl text-5xl font-black leading-[0.95] text-zinc-950 sm:text-6xl lg:text-7xl animate-fade-up" style="animation-delay: 80ms;">
              Book the next high-output session.
            </h1>
            <p class="mt-6 max-w-2xl text-lg leading-8 text-zinc-700 animate-fade-up" style="animation-delay: 160ms;">
              {BUSINESS_NAME} turns Wix Headless scheduling into a fast, branded path from intent to confirmed training. Members can compare sessions, pick a live slot, and keep the momentum moving.
            </p>
            <div class="mt-8 flex flex-col gap-3 sm:flex-row animate-fade-up" style="animation-delay: 240ms;">
              <a href="/schedule" class="inline-flex justify-center rounded-lg bg-primary px-6 py-3 text-sm font-black uppercase tracking-wide text-white shadow-[0_16px_40px_rgba(227,22,71,0.28)] transition-colors hover:bg-primary/90">
                Book a Session
              </a>
              <a href="#programs" class="inline-flex justify-center rounded-lg border border-zinc-950/20 bg-white/70 px-6 py-3 text-sm font-bold text-zinc-950 transition-colors hover:border-primary hover:text-primary">
                See Programs
              </a>
            </div>
            <div class="mt-10 grid max-w-xl grid-cols-3 gap-3 animate-fade-up" style="animation-delay: 320ms;">
              <div class="border-l-4 border-primary bg-white/75 p-4">
                <p class="text-2xl font-black text-zinc-950">30</p>
                <p class="text-xs font-bold uppercase text-zinc-500">Min intro</p>
              </div>
              <div class="border-l-4 border-accent bg-white/75 p-4">
                <p class="text-2xl font-black text-zinc-950">60</p>
                <p class="text-xs font-bold uppercase text-zinc-500">Min block</p>
              </div>
              <div class="border-l-4 border-secondary bg-white/75 p-4">
                <p class="text-2xl font-black text-zinc-950">Live</p>
                <p class="text-xs font-bold uppercase text-zinc-500">Slots</p>
              </div>
            </div>
          </div>

          <div class="shift-booking-visual animate-slide-in-right">
            <div class="shift-visual-header">
              <span>Tonight's training board</span>
              <strong>Wix Bookings</strong>
            </div>
            <div class="shift-session-row is-hot">
              <span>Power Circuit</span>
              <strong>6:30 PM</strong>
            </div>
            <div class="shift-session-row">
              <span>Mobility Reset</span>
              <strong>7:15 PM</strong>
            </div>
            <div class="shift-session-row is-accent">
              <span>Performance Session</span>
              <strong>8:00 PM</strong>
            </div>
            <div class="shift-meter">
              <span style="width: 82%"></span>
            </div>
            <p>Availability, booking, and paid service checkout are wired into one headless experience.</p>
          </div>
        </div>
      </section>

      <section id="programs" class="bg-zinc-950 py-16 text-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
            <div>
              <p class="text-sm font-black uppercase tracking-wide text-secondary">Programs in motion</p>
              <h2 class="mt-3 max-w-2xl text-3xl font-black md:text-4xl">A booking flow with studio energy.</h2>
            </div>
            <p class="max-w-xl text-sm leading-6 text-white/60">
              The site keeps Wix as the operational source of truth while the front end carries the pace, attitude, and clarity of the brand.
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {features.map((feature, index) => (
              <div class="rounded-lg border border-white/10 bg-white/10 p-6 transition-colors hover:bg-white/20 animate-fade-up" style={`animation-delay: ${index * 100 + 200}ms`}>
                <p class="mb-8 text-sm font-black text-accent">{feature.marker}</p>
                <h3 class="text-xl font-black mb-3">{feature.title}</h3>
                <p class="text-sm leading-6 text-white/70">{feature.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="py-16 bg-primary">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-center">
            <div class="animate-fade-up">
              <p class="text-sm font-black uppercase tracking-wide text-white/70">Ready window, real inventory</p>
              <h2 class="mt-3 max-w-3xl text-3xl font-black text-white md:text-5xl">Let members claim the slot while motivation is fresh.</h2>
            </div>
            <a href="/schedule" class="inline-flex justify-center rounded-lg bg-zinc-950 px-6 py-3 text-sm font-black uppercase tracking-wide text-white transition-colors hover:bg-zinc-800 animate-fade-up" style="animation-delay: 120ms;">
              Open Scheduler
            </a>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>
