---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import { BUSINESS_NAME } from "../utils/constants";

const features = [
  {
    title: "Live studio availability",
    description: "Open windows come straight from Wix Bookings, so members see the same inventory your staff sees.",
    marker: "01",
  },
  {
    title: "Free or paid sessions",
    description: "Intro assessments can confirm directly while premium blocks can continue into Wix checkout.",
    marker: "02",
  },
  {
    title: "Fast confirmation loop",
    description: "Date, time, contact details, and confirmation stay inside a branded path built for momentum.",
    marker: "03",
  },
];

const programs = [
  {
    title: "Intro Assessment",
    meta: "30 min / no-fee",
    description: "A quick movement screen for new members before the first full training block.",
  },
  {
    title: "Performance Session",
    meta: "60 min / checkout",
    description: "A paid coached block that moves from slot selection into the Wix checkout flow.",
  },
  {
    title: "Mobility Reset",
    meta: "live capacity",
    description: "A recovery-focused session where availability updates as the studio calendar changes.",
  },
];

const flow = ["Select a session", "Scan live slots", "Confirm or checkout"];
---

<Layout>
  <div class="min-h-screen overflow-hidden bg-[#f7f8ef] text-foreground">
    <Navbar />

    <main>
      <section class="shift-hero relative pt-28 pb-12 md:pt-34 md:pb-16">
        <div class="max-w-7xl mx-auto grid gap-10 px-4 sm:px-6 lg:grid-cols-[1.02fr_0.98fr] lg:items-center lg:px-8">
          <div>
            <p class="mb-5 inline-flex rounded-lg bg-zinc-950 px-3 py-2 text-xs font-black uppercase tracking-wide text-white shadow-[6px_6px_0_hsl(83_85%_88%)] animate-fade-up">
              Live Wix Bookings engine
            </p>
            <h1 class="max-w-4xl text-5xl font-black leading-[0.92] text-zinc-950 sm:text-6xl lg:text-7xl animate-fade-up" style="animation-delay: 80ms;">
              High-intensity booking without the generic scheduler.
            </h1>
            <p class="mt-6 max-w-2xl text-lg leading-8 text-zinc-700 animate-fade-up" style="animation-delay: 160ms;">
              {BUSINESS_NAME} turns Wix Headless scheduling into a bold training desk: members compare programs, claim real availability, and either confirm or continue to checkout while the energy is still high.
            </p>
            <div class="mt-8 flex flex-col gap-3 sm:flex-row animate-fade-up" style="animation-delay: 240ms;">
              <a href="/schedule" class="inline-flex justify-center rounded-lg bg-primary px-6 py-3 text-sm font-black uppercase tracking-wide text-white shadow-[0_18px_44px_rgba(227,22,71,0.32)] transition-transform hover:-translate-y-0.5 hover:bg-primary/90">
                Book a Session
              </a>
              <a href="#programs" class="inline-flex justify-center rounded-lg border border-zinc-950/20 bg-white/80 px-6 py-3 text-sm font-bold text-zinc-950 transition-colors hover:border-primary hover:text-primary">
                Compare Programs
              </a>
            </div>
            <div class="mt-10 grid max-w-2xl grid-cols-3 gap-3 animate-fade-up" style="animation-delay: 320ms;">
              <div class="shift-stat-tile border-primary">
                <p>30</p>
                <span>Min intro</span>
              </div>
              <div class="shift-stat-tile border-accent">
                <p>60</p>
                <span>Min paid block</span>
              </div>
              <div class="shift-stat-tile border-secondary">
                <p>Live</p>
                <span>Wix slots</span>
              </div>
            </div>
          </div>

          <div class="shift-booking-visual animate-slide-in-right">
            <div class="shift-visual-header">
              <span>Tonight's training board</span>
              <strong>Wix live</strong>
            </div>
            <div class="shift-session-row is-hot">
              <span><b>Power Circuit</b><small>4 spots left</small></span>
              <strong>6:30 PM</strong>
            </div>
            <div class="shift-session-row">
              <span><b>Mobility Reset</b><small>open</small></span>
              <strong>7:15 PM</strong>
            </div>
            <div class="shift-session-row is-accent">
              <span><b>Performance Session</b><small>checkout enabled</small></span>
              <strong>8:00 PM</strong>
            </div>
            <div class="shift-meter">
              <span style="width: 82%"></span>
            </div>
            <div class="shift-board-footer">
              <span>82% evening capacity</span>
              <span>NO_FEE + FIXED services</span>
            </div>
            <p>Availability, booking, and paid service checkout are wired into one headless experience.</p>
          </div>
        </div>

        <div class="max-w-7xl mx-auto mt-12 px-4 sm:px-6 lg:px-8">
          <div class="shift-class-strip animate-fade-up" style="animation-delay: 420ms;">
            {programs.map((program) => (
              <article>
                <p>{program.meta}</p>
                <h3>{program.title}</h3>
                <span>{program.description}</span>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="programs" class="bg-zinc-950 py-16 text-white md:py-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
            <div>
              <p class="text-sm font-black uppercase tracking-wide text-secondary">Programs in motion</p>
              <h2 class="mt-3 max-w-2xl text-3xl font-black md:text-5xl">A booking flow that feels like the warmup already started.</h2>
            </div>
            <p class="max-w-xl text-sm leading-6 text-white/60">
              The site keeps Wix as the operational source of truth while the front end carries the pace, attitude, and clarity of the brand.
            </p>
          </div>

          <div class="grid grid-cols-1 gap-5 md:grid-cols-3">
            {features.map((feature, index) => (
              <div class="shift-feature-card animate-fade-up" style={`animation-delay: ${index * 100 + 200}ms`}>
                <p class="mb-8 text-sm font-black text-accent">{feature.marker}</p>
                <h3 class="text-xl font-black mb-3">{feature.title}</h3>
                <p class="text-sm leading-6 text-white/70">{feature.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="shift-flow-section py-16 md:py-20">
        <div class="max-w-7xl mx-auto grid gap-8 px-4 sm:px-6 lg:grid-cols-[0.78fr_1fr] lg:items-center lg:px-8">
          <div>
            <p class="text-sm font-black uppercase tracking-wide text-primary">Headless path</p>
            <h2 class="mt-3 text-3xl font-black leading-tight text-zinc-950 md:text-5xl">
              Service selection, live availability, and confirmation all carry the brand.
            </h2>
          </div>
          <div class="grid gap-3 sm:grid-cols-3">
            {flow.map((item, index) => (
              <div class="shift-flow-step">
                <span>{index + 1}</span>
                <strong>{item}</strong>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="bg-primary py-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-center">
            <div class="animate-fade-up">
              <p class="text-sm font-black uppercase tracking-wide text-white/70">Ready window, real inventory</p>
              <h2 class="mt-3 max-w-3xl text-3xl font-black text-white md:text-5xl">Let members claim the slot while motivation is fresh.</h2>
            </div>
            <a href="/schedule" class="inline-flex justify-center rounded-lg bg-zinc-950 px-6 py-3 text-sm font-black uppercase tracking-wide text-white transition-transform hover:-translate-y-0.5 hover:bg-zinc-800 animate-fade-up" style="animation-delay: 120ms;">
              Open Scheduler
            </a>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>
