---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Panel from "../components/ui/Panel.astro";
import BackButton from "../components/ui/BackButton.astro";
import Icon from "../components/ui/Icon.astro";
import "../styles/global.css";
import { BUSINESS_NAME } from "../utils/constants";
---

<Layout>
  <div class="min-h-screen bg-[#f7f8ef]">
    <Navbar />

    <div class="max-w-5xl mx-auto pt-32 pb-16 px-4">
      <div class="mb-6">
        <BackButton href="/" text="Back to Home" />
      </div>

      <Panel padding="none" class="overflow-hidden">
        <div class="grid md:grid-cols-[0.9fr_1.1fr]">
          <div class="bg-zinc-950 p-8 text-white md:p-10">
            <div
              class="mb-6 inline-flex h-16 w-16 items-center justify-center rounded-lg bg-primary text-white shadow-[8px_8px_0_hsl(83_85%_88%)] animate-scale-in"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-8 w-8"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                <polyline points="22 4 12 14.01 9 11.01"></polyline>
              </svg>
            </div>

            <div class="animate-fade-up">
              <p class="text-sm font-black uppercase tracking-wide text-secondary">Booking confirmed</p>
              <h1 class="mt-3 text-4xl font-black leading-tight md:text-5xl">Your training window is locked.</h1>
            </div>

            <div class="animate-fade-up delay-100">
              <p class="mt-5 max-w-xl text-white/70">
                Your session with {BUSINESS_NAME} is scheduled. We sent the confirmation to <span id="confirmation-email" class="font-bold text-white">your email</span>.
              </p>
            </div>
          </div>

          <div id="appointment-details" class="p-8 md:p-10 animate-fade-up delay-200">
            <div class="mb-6 flex items-center justify-between gap-4">
              <div>
                <p class="text-xs font-black uppercase tracking-wide text-primary">Session Details</p>
                <h2 class="mt-1 text-2xl font-black text-zinc-950">Ready for check-in</h2>
              </div>
              <Icon name="calendar" class="text-primary" />
            </div>

            <div class="grid gap-3 text-left">
              <p class="shift-confirm-row">
                <span>Name</span>
                <strong id="confirmation-name">Your Name</strong>
              </p>
              <p class="shift-confirm-row">
                <span>Date</span>
                <strong id="confirmation-date">Date</strong>
              </p>
              <p class="shift-confirm-row">
                <span>Time</span>
                <strong id="confirmation-time">Time</strong>
              </p>
              <p class="shift-confirm-row">
                <span>Email</span>
                <strong id="confirmation-email-details">Email</strong>
              </p>
              <p class="shift-confirm-row">
                <span>Phone</span>
                <strong id="confirmation-phone">Phone</strong>
              </p>
              <p id="confirmation-notes-container" class="shift-confirm-row hidden">
                <span>Notes</span>
                <strong id="confirmation-notes">Notes</strong>
              </p>
            </div>

            <div class="mt-8 flex flex-col gap-3 sm:flex-row">
              <a
                href="/"
                class="inline-flex justify-center rounded-lg border border-zinc-300 bg-white px-4 py-3 text-sm font-bold text-zinc-950 transition-colors hover:border-primary hover:text-primary"
              >
                Return to Home
              </a>
              <a
                href="/schedule"
                class="inline-flex justify-center rounded-lg bg-primary px-4 py-3 text-sm font-black uppercase tracking-wide text-white transition-colors hover:bg-primary/90"
              >
                Book Another Session
              </a>
            </div>
          </div>
        </div>
      </Panel>
    </div>

    <Footer />
  </div>
</Layout>

<script>
  import type { BookingData } from "../utils/booking-service";

  // Retrieve booking data from sessionStorage
  function getBookingData(): BookingData | null {
    const data = sessionStorage.getItem("bookingData");

    if (!data) {
      // Redirect if no booking data is found
      window.location.href = "/schedule";
      return null;
    }

    return JSON.parse(data) as BookingData;
  }

  // Update confirmation page with booking data
  function updateConfirmationDetails(): void {
    const bookingData = getBookingData();
    if (!bookingData) return;

    // Update email in header
    const emailElement = document.getElementById("confirmation-email");
    if (emailElement) {
      emailElement.textContent = bookingData.email;
    }

    // Update appointment details
    updateElementText("confirmation-name", bookingData.name);
    updateElementText("confirmation-date", bookingData.displayDate || "");
    updateElementText("confirmation-time", bookingData.displayTime || "");
    updateElementText("confirmation-email-details", bookingData.email);
    updateElementText("confirmation-phone", bookingData.phone);

    // Handle optional notes
    if (bookingData.notes && bookingData.notes.trim()) {
      updateElementText("confirmation-notes", bookingData.notes);

      const notesContainer = document.getElementById(
        "confirmation-notes-container"
      );
      if (notesContainer) {
        notesContainer.classList.remove("hidden");
      }
    }
  }

  // Helper function to update text content of an element
  function updateElementText(id: string, text: string): void {
    const element = document.getElementById(id);
    if (element) {
      element.textContent = text;
    }
  }

  // Initialize page
  document.addEventListener("DOMContentLoaded", updateConfirmationDetails);
</script>
