---
import "../styles/global.css";
import { BUSINESS_NAME } from "../utils/constants";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${BUSINESS_NAME} | Performance Booking`,
  description = "Book studio sessions through a Wix Headless scheduling experience.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
